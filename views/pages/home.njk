{% from "panel/macro.njk" import govukPanel %}
{% from "summary-list/macro.njk" import govukSummaryList %}
{% from "button/macro.njk" import govukButton %}

<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    {{ govukPanel({
      titleText: site.name,
      html: "<p class=\"govuk-body-l\">Software engineer building accessible, user-centred digital services.</p>"
    }) }}

    <h2 class="govuk-heading-l">About me</h2>
    <p class="govuk-body">
      I design and build reliable web applications with a focus on accessibility,
      performance, and maintainable code. This portfolio is built with the
      <a class="govuk-link" href="https://design-system.service.gov.uk/">GOV.UK Design System</a>.
    </p>

    <h2 class="govuk-heading-l">Skills</h2>
    {{ govukSummaryList({
      rows: [
        { key: { text: "Languages" }, value: { text: "TypeScript, JavaScript, HTML, CSS" } },
        { key: { text: "Backend" }, value: { text: "Node.js, Express, REST APIs" } },
        { key: { text: "Frontend" }, value: { text: "SSR, component libraries, accessibility" } },
        { key: { text: "Practices" }, value: { text: "Testing, CI/CD, design systems" } }
      ]
    }) }}

    <div class="govuk-button-group">
      {{ govukButton({ text: "View my work", href: basePath + "work/" }) }}
      {{ govukButton({ text: "Get in touch", href: basePath + "contact/", classes: "govuk-button--secondary" }) }}
    </div>
  </div>
</div>
