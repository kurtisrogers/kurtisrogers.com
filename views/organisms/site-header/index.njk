<header class="site-header" role="banner">
  <div class="container header-inner">
    <a href="/" class="site-logo">{{ site.name }}</a>

    <nav id="site-nav" class="site-nav" aria-label="Main navigation" :class="{ 'is-open': navOpen }">
      <ul role="list">
        <li>
          {% set href = "/" %}{% set label = "Home" %}
          {% include "molecules/nav-link/index.njk" %}
        </li>
        <li>
          {% set href = "/about" %}{% set label = "About" %}
          {% include "molecules/nav-link/index.njk" %}
        </li>
        <li>
          {% set href = "/contact" %}{% set label = "Contact" %}
          {% include "molecules/nav-link/index.njk" %}
        </li>
      </ul>
    </nav>

    <div class="header-actions">
      {% include "atoms/theme-toggle/index.njk" %}
      <button
        type="button"
        class="nav-toggle"
        @click="navOpen = !navOpen"
        :aria-expanded="navOpen.toString()"
        aria-controls="site-nav"
        aria-label="Toggle navigation menu"
      >
        <span aria-hidden="true">☰</span>
      </button>
    </div>
  </div>
</header>
