<section class="hero-banner" aria-labelledby="hero-heading">
  <div class="container">
    <h1 id="hero-heading">{{ heading }}</h1>
    {% if subheading %}<p class="hero-subheading">{{ subheading }}</p>{% endif %}
    {% if tagline %}<p class="hero-tagline">{{ tagline }}</p>{% endif %}
  </div>
</section>
