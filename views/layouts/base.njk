{% from "skip-link/macro.njk" import govukSkipLink %}
{% from "header/macro.njk" import govukHeader %}
{% from "phase-banner/macro.njk" import govukPhaseBanner %}
{% from "footer/macro.njk" import govukFooter %}
{% from "service-navigation/macro.njk" import govukServiceNavigation %}

<!DOCTYPE html>
<html class="govuk-template" lang="en">
  <head>
    <meta charset="utf-8">
    <title>{{ title }}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <meta name="theme-color" content="#0b0c0c">
    <meta name="description" content="{{ site.description }}">

    <link rel="stylesheet" href="{{ basePath }}assets/govuk/govuk-frontend.min.css">
  </head>

  <body class="govuk-template__body">
    <script>
      document.body.className += ' js-enabled' + ('noModule' in HTMLScriptElement.prototype ? ' govuk-frontend-supported' : '');
    </script>

    {{ govukSkipLink({ text: "Skip to main content", href: "#main-content" }) }}

    {{ govukHeader({
      homepageUrl: basePath,
      serviceName: site.name,
      container: false
    }) }}

    {{ govukPhaseBanner({
      tag: { text: "Portfolio" },
      html: "This site demonstrates the <a class=\"govuk-link\" href=\"https://design-system.service.gov.uk/\">GOV.UK Design System</a>. Browse all components in <a class=\"govuk-link\" href=\"" + basePath + "storybook/\">Storybook</a>."
    }) }}

    {{ govukServiceNavigation({
      serviceName: site.name,
      navigation: [
        { text: "Home", href: basePath, active: activeNav == "home" },
        { text: "About", href: basePath + "about/", active: activeNav == "about" },
        { text: "Work", href: basePath + "work/", active: activeNav == "work" },
        { text: "Contact", href: basePath + "contact/", active: activeNav == "contact" }
      ]
    }) }}

    <div class="govuk-width-container">
      <main class="govuk-main-wrapper" id="main-content" role="main">
        {% include contentTemplate %}
      </main>
    </div>

    {{ govukFooter({
      meta: {
        items: [
          { href: site.github, text: "GitHub" },
          { href: basePath + "storybook/", text: "Component library" }
        ]
      }
    }) }}

    <script type="module" src="{{ basePath }}assets/govuk/govuk-frontend.min.js"></script>
    <script type="module">
      import { initAll } from "{{ basePath }}assets/govuk/govuk-frontend.min.js";
      initAll();
    </script>
  </body>
</html>
