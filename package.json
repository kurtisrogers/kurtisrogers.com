{
  "name": "kurtisrogers.com",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsx src/build.ts",
    "start": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "generate:stories": "tsx scripts/generate-govuk-stories.ts",
    "storybook": "npm run generate:stories && storybook dev -p 6006",
    "build-storybook": "npm run generate:stories && storybook build -o storybook-static",
    "build:site": "npm run build && npm run build-storybook && cp -r storybook-static dist/storybook"
  },
  "dependencies": {
    "express": "^5.1.0",
    "govuk-frontend": "^6.3.0",
    "nunjucks": "^3.2.4"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.6.14",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-links": "^8.6.14",
    "@storybook/html-vite": "^8.6.14",
    "@types/express": "^5.0.1",
    "@types/node": "^22.14.1",
    "@types/nunjucks": "^3.2.6",
    "storybook": "^8.6.14",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vite": "^5.4.19"
  }
}
